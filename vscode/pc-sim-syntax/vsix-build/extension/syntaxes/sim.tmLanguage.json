{
  "scopeName": "source.pcsim",
  "name": "PC Sim",
  "patterns": [
    { "include": "#comments" },
    { "include": "#directives" },
    { "include": "#wireType" },
    { "include": "#componentName" },
    { "include": "#keyValueBoolean" },
    { "include": "#keyValueNumber" },
    { "include": "#keyValueString" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.pcsim",
          "match": "#.*$"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "keyword.control.directive.pcsim",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "wireType": {
      "patterns": [
        {
          "name": "keyword.other.wire.pcsim",
          "match": "\\bwire\\b(?=\\s*\\()"
        }
      ]
    },
    "componentName": {
      "patterns": [
        {
          "name": "entity.name.function.component.pcsim",
          "match": "\\b[a-z_][a-z0-9_]*\\b(?=\\s*\\()"
        }
      ]
    },
    "keyValueBoolean": {
      "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(=)\\s*(True|False|true|false)(?=[,);\\s]|$)",
      "captures": {
        "1": { "name": "variable.parameter.key.pcsim" },
        "2": { "name": "keyword.operator.assignment.pcsim" },
        "3": { "name": "constant.language.boolean.pcsim" }
      }
    },
    "keyValueNumber": {
      "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(=)\\s*(-?\\d+(?:\\.\\d+)?)(?=[,);\\s]|$)",
      "captures": {
        "1": { "name": "variable.parameter.key.pcsim" },
        "2": { "name": "keyword.operator.assignment.pcsim" },
        "3": { "name": "constant.numeric.pcsim" }
      }
    },
    "keyValueString": {
      "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(=)\\s*([^,);]*)",
      "captures": {
        "1": { "name": "variable.parameter.key.pcsim" },
        "2": { "name": "keyword.operator.assignment.pcsim" },
        "3": { "name": "string.unquoted.value.pcsim" }
      }
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.statement.pcsim",
          "match": ";"
        },
        {
          "name": "punctuation.section.parens.begin.pcsim",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.pcsim",
          "match": "\\)"
        },
        {
          "name": "punctuation.separator.comma.pcsim",
          "match": ","
        }
      ]
    }
  }
}
